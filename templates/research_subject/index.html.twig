{% extends 'base.html.twig' %}

{% block title %}Sujets de recherche{% endblock %}

{% block body %}
    <h1>Sujets de recherche</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titre</th>
                <th>Slug</th>
                <th>Extrait</th>
                <th>Créé le</th>
                <th>Modifié le</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for research_subject in research_subjects %}
            <tr>
                <td>{{ research_subject.id }}</td>
                <td>{{ research_subject.title }}</td>
                <td>{{ research_subject.slug }}</td>
                <td>
                    {{ research_subject.content|striptags|slice(0, 120) }}
                    {% if research_subject.content|striptags|length > 120 %}
                        ...
                    {% endif %}
                </td>
                <td>{{ research_subject.createdAt ? research_subject.createdAt|date('d/m/Y H:i') : '' }}</td>
                <td>{{ research_subject.updatedAt ? research_subject.updatedAt|date('d/m/Y H:i') : '' }}</td>
                <td>{{ research_subject.status }}</td>
                <td>
                    <a href="{{ path('app_research_subject_show', {'id': research_subject.id}) }}">Voir admin</a>

                    <a href="{{ path('app_research_subject_edit', {'id': research_subject.id}) }}">Modifier</a>

                    {% if research_subject.status == constant('App\\Entity\\ResearchSubject::STATUS_PUBLISHED') %}
                        <a href="{{ path('app_public_research_show', {'slug': research_subject.slug}) }}">Voir public</a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">Aucun sujet de recherche trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_research_subject_new') }}">Créer un nouveau sujet</a>
{% endblock %}